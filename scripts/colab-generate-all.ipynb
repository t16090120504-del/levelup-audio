SCRIPTS_DIR = "/content/levelup-audio/assets/scripts"
BASE_OUTPUT = "/content/output"


def extract_episode_text(filepath):
    """从 Markdown 剧本中提取每集文本"""
    with open(filepath, "r", encoding="utf-8") as f:
        content = f.read()

    episodes = []
    parts = re.split(r'## Episode \d+:', content)

    for idx, part in enumerate(parts[1:], start=1):
        lines = part.strip().split('\n')
        title_line = ""
        for line in lines:
            stripped = line.strip()
            if stripped:
                title_line = stripped.strip('"').strip("'")
                break

        narration_parts = []
        for line in lines:
            stripped = line.strip()
            if not stripped:
                continue
            if stripped.startswith('**') and ('Duration' in stripped or 'Genre' in stripped):
                continue
            if stripped.startswith('[') and stripped.endswith(']'):
                continue
            if stripped.startswith('[end') or stripped.startswith('[beat'):
                continue
            if stripped == '[narration begins]':
                continue
            if stripped == title_line:
                continue
            narration_parts.append(stripped)

        narration_text = "\n".join(narration_parts).strip()
        if narration_text:
            episodes.append((idx, title_line, narration_text))

    return episodes


def clean_text(text):
    """清理文本格式"""
    clean = text.replace('"', '"').replace('"', '"').replace("'", "'").replace("'", "'")
    clean = clean.replace("---", "—").replace("--", "—")
    clean = re.sub(r'\*\*([^*]+)\*\*', r'\1', clean)
    clean = re.sub(r'\*([^*]+)\*', r'\1', clean)
    clean = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', clean)
    clean = re.sub(r'\n{2,}', '. ', clean)
    clean = re.sub(r'\n', '. ', clean)
    clean = re.sub(r'\.{3,}', '...', clean)
    clean = re.sub(r'\.{2}', '. ', clean)
    clean = re.sub(r' {2,}', ' ', clean)
    return clean.strip()


async def generate_episode(ep_num, title, text, voice, output_dir, rate="-5%"):
    """生成单集音频"""
    os.makedirs(output_dir, exist_ok=True)
    safe_title = re.sub(r'[^a-zA-Z0-9\s-]', '', title).strip().lower()
    safe_title = re.sub(r'\s+', '-', safe_title)[:50]
    output_file = os.path.join(output_dir, f"ep{ep_num:02d}-{safe_title}.mp3")

    clean_text_val = clean_text(text)
    if not clean_text_val or len(clean_text_val) < 20:
        return None

    communicate = edge_tts.Communicate(clean_text_val, voice, rate=rate)
    await communicate.save(output_file)
    return output_file


async def generate_series(config, start_episode=1):
    """生成一个系列的全部音频"""
    script_path = os.path.join(SCRIPTS_DIR, config["script"])
    output_dir = os.path.join(BASE_OUTPUT, config["output"])

    if not os.path.exists(script_path):
        print(f"  ⚠️ 剧本不存在: {config['script']}")
        return []

    episodes = extract_episode_text(script_path)
    if not episodes:
        print(f"  ⚠️ 没有找到剧集: {config['script']}")
        return []

    print(f"\n{'='*60}")
    print(f"  📖 {config['name']}")
    print(f"  🎙️  {config['voice']} ({config['voice_desc']})")
    print(f"  📁 输出: {config['output']}")
    print(f"  📝 共 {len(episodes)} 集")
    print(f"{'='*60}")

    generated = []
    for ep_num, title, text in episodes:
        if ep_num < start_episode:
            continue
        result = await generate_episode(ep_num, title, text, config["voice"], output_dir)
        if result:
            size = os.path.getsize(result) / 1024
            print(f"  ✅ Episode {ep_num}: {title} ({size:.1f} KB)")
            generated.append(result)
        else:
            print(f"  ⏭️  Episode {ep_num}: 跳过（文本太短）")

    return generated


async def main():
    os.makedirs(BASE_OUTPUT, exist_ok=True)
    print("=" * 60)
    print("  LevelUp Audio - 全系列音频生成")
    print(f"  开始时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
