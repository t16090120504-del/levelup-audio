    print("=" * 60)

    all_results = {}

    for i, config in enumerate(SERIES_CONFIG):
        print(f"\n[{i+1}/{len(SERIES_CONFIG)}] 正在生成: {config['name']}")
        generated = await generate_series(config)
        all_results[config["name"]] = {
            "voice": config["voice"],
            "episodes": len(generated),
            "output_dir": config["output"],
